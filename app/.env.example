APP_NAME=SmartLogisticsTest
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL="http://${APP_SERVER_URL}"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL — credentials from project root .env (POSTGRESQL_*)
# Docker: DB_HOST=postgresql, DB_PORT=5432 | Host machine: DB_HOST=127.0.0.1, DB_PORT=${POSTGRESQL_PORT}
DB_CONNECTION=pgsql
DB_HOST=postgresql
DB_PORT="${POSTGRESQL_PORT}"
DB_DATABASE="${POSTGRESQL_DATABASE}"
DB_USERNAME="${POSTGRESQL_USER}"
DB_PASSWORD="${POSTGRESQL_PASSWORD}"

# Redis — host/port from project root .env (REDIS_HOST, REDIS_HTTPS_PORT on host)
# Docker: REDIS_HOST=redis, REDIS_PORT=6379 | Host machine: REDIS_HOST=127.0.0.1, REDIS_PORT=${REDIS_HTTPS_PORT}
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT="${REDIS_HTTPS_PORT}"

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=rabbitmq

# RabbitMQ — credentials from project root .env (RABBITMQ_DEFAULT_*)
# Docker: RABBITMQ_HOST=rabbitmq | Host machine: RABBITMQ_HOST=127.0.0.1
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT="${RABBITMQ_PORT}"
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
