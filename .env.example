# Ports (host:container)
POSTGRESQL_PORT=3306
PHP_FPM_PORT=9001
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
REDIS_HTTPS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_DEFAULT_VHOST=/

# MySQL credentials
POSTGRESQL_ROOT_PASSWORD=root
POSTGRESQL_USER=user
POSTGRESQL_PASSWORD=user
POSTGRESQL_DATABASE=smartlogisticstest

# Nginx server (app) settings
APP_PATH=SmartLogisticsTest
APP_SERVER_URL=localhost

